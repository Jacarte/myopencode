{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "atlassian": {
      "enabled": true,
      "type": "remote",
      "oauth": {},
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "slack": {
      "type": "local",
      "command": [
        "/Users/javcab/myslacky/env/bin/python",
        "-u",
        "/Users/javcab/myslacky/server.py"
      ],
      "enabled": true,
      "environment": {
        "SLACK_BOT_TOKEN": "{env:SLACK_BOT_TOKEN}"
      }
    },
    "anytype": {
      "command": [
        "npx",
        "-y",
        "@anyproto/anytype-mcp"
      ],
      "type": "local",
      "environment": {
        "OPENAPI_MCP_HEADERS": "{env:OPENAPI_MCP_HEADERS}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "browsermcp": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "@browsermcp/mcp@0.1.3"
      ]
    },
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@0.0.68"
      ]
    },
    "prometheus": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "PROMETHEUS_URL",
        "ghcr.io/pab1it0/prometheus-mcp-server"
      ],
      "environment": {
        "PROMETHEUS_URL": "http://host.docker.internal:54671"
      }
    },
    "kitty_terminal": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "{env:HOME}/.config/opencode/mcps/kitty-terminal-mcp/server.mjs"
      ],
      "environment": {
        "KITTY_LISTEN_ON": "unix:/tmp/kitten"
      }
    },
    "gitlab": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "{env:HOME}/.config/opencode/mcps/gitlab-mr-service-mcp-node/server.mjs"
      ],
      "environment": {
        "GITLAB_TOKEN": "{env:GITLAB_TOKEN}"
      }
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp"
    }
  },
  "plugin": [
    "oh-my-opencode@3.13.1",
    "./plugins/mem0-functional.ts"
  ]
}
