{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": [
        "openai/gpt-5.4",
        "azure/gpt-5.4-pro"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "fallback_models": [
        "openai/gpt-5.4",
        "azure/gpt-5.3-codex"
      ]
    },
    "oracle": {
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": [
        "openai/gpt-5.4",
        "github-copilot/gpt-5.4"
      ]
    },
    "librarian": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "anthropic/claude-haiku-4-5",
        "azure/claude-haiku-4-5"
      ]
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": [
        "anthropic/claude-haiku-4-5",
        "openai/gpt-5.1-codex-mini"
      ]
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "github-copilot/gpt-5.1"
      ]
    },
    "prometheus": {
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel.",
      "model": "",
      "fallback_models": []
    },
    "metis": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.4",
        "azure/claude-sonnet-4-5"
      ]
    },
    "momus": {
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "azure/claude-opus-4-6"
      ]
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "github-copilot/gpt-5.1"
      ]
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "github-copilot/claude-haiku-4.5",
        "github-copilot/gpt-5.1"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": [
        "openai/gpt-5.2",
        "github-copilot/gpt-5.2",
        "azure/gpt-5.2"
      ]
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "openai/gpt-5.2"
      ]
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.4",
        "github-copilot/gpt-5.4"
      ]
    },
    "writing": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "openai/gpt-5.4"
      ]
    },
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "git": {
      "model": "openai/gpt-5.2",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations.",
      "fallback_models": [
        "anthropic/claude-haiku-4-5"
      ]
    }
  },
  "_migrations": [
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:openai/gpt-5.2-codex->openai/gpt-5.3-codex",
    "model-version:anthropic/claude-opus-4-5->anthropic/claude-opus-4-6"
  ],
  "background_task": {
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 3,
      "github-copilot": 6
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 2,
      "github-copilot/gpt-5-mini": 20
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 30,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
