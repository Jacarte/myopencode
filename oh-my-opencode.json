{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "hephaestus": {
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.3-codex"
    },
    "librarian": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "explore": {
      "model": "github-copilot/claude-opus-4.5"
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash-preview"
    },
    "prometheus": {
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel."
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6"
    },
    "momus": {
      "model": "openai/gpt-5.2"
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-opus-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "github-copilot/gpt-5-mini"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "writing": {
      "model": "github-copilot/gemini-3.1-pro-preview"
    },
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "git": {
      "model": "github-copilot/gpt-5-mini",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "_migrations": [
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:openai/gpt-5.2-codex->openai/gpt-5.3-codex"
  ],
  "background_task": {
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 3,
      "github-copilot": 6
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 2,
      "github-copilot/gpt-5-mini": 20
    }
  }
}
